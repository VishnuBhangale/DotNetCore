@model PraticeWebApplication.Models.AdditionModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_LayoutMaster.cshtml";
}

<h1>Index</h1>

<h4>Addition</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Index">
